# Copy this file to /etc/beremiz-stand/stand.conf and adjust it for the stand.
# Local source paths are needed only by deploy/build/measurement commands.

[pc]
rt_tester_dir = /usr/share/rt-tester-tools
rt_supervisor_dir = /path/to/rt-supervisor
rt_controller_dir = /path/to/rt-controller
arduino_port = /dev/ttyACM0
ethernet_iface = enp2s0
ethernet_connection = stand-wired
ethernet_addr = 10.42.0.1/24
controller_route = 10.43.0.0/24
controller_gateway = 10.42.0.211
ssh_public_key = /home/user/.ssh/id_ed25519.pub
trace_prometheus_url = http://127.0.0.1:9091
trace_prometheus_addr = 127.0.0.1:9091
trace_grafana_addr = 127.0.0.1:3001

[supervisor]
ssh = root@10.43.0.2
label = supervisor-board
board = rockpi4
iface = end0
pc_iface = end0
pc_connection = end0-static
pc_addr = 10.43.0.2/24
controller_iface = end0
controller_connection = end0-static
controller_addr = 10.43.0.2/24
enable_ip_forward = no
rt_supervisor_dir = /root/rt-supervisor
beremiz_stand_dir = /root/beremiz-stand
plc_project = beremiz-project/supervised-raw-plc
runtime_dir = /root/beremiz-runtime/supervised-raw-plc
runtime_bind_ip = 10.43.0.2
runtime_port = 3000
supervisor_bin = /usr/bin/alt-rt-supervisor
runner = /usr/share/rt-supervisor/scripts/run_supervisor.sh
trace_exporter = /usr/share/rt-supervisor/scripts/trace_exporter.py
runtime_wrapper = /usr/bin/runtime
erpc_url = ERPC://10.43.0.2:3000
pinning_script = /usr/share/rt-supervisor/scripts/pin_stand.sh /usr/share/rt-supervisor/configs/stand/supervised-rockpi4.conf

[controller]
ssh = root@10.42.0.211
ssh_jump = root@10.42.0.211
label = controller-board
board = visionfive2
iface = end0
connection = end0-static
addr = 10.43.0.1/24
pc_route = 10.42.0.0/24
pc_gateway = 10.42.0.211
uart = /dev/ttyUSB0
uart_baud = 1500000
rt_controller_dir = /root/rt-controller
controller_bin = /usr/bin/controller-emu
runner = /usr/share/rt-controller/scripts/run_controller.sh
trace_exporter = /usr/share/rt-controller/scripts/trace_exporter.py
pinning_script = /usr/share/rt-controller/scripts/pin_stand.sh /usr/share/rt-controller/configs/stand/controller-visionfive2.conf

[measurement]
params = /usr/share/rt-tester-tools/src/pc-receiver/measurement-supervised-smoke.conf
groups = 2
measurements_per_group = 1500
interval_us = 5000
receiver_timeout_sec = 120
