  <types>
    <dataTypes/>
    <pous>
      <pou name="plc_prg" pouType="program">
        <interface>
          <externalVars>
            <variable name="RawSensorValue"><type><UINT/></type></variable>
            <variable name="RawThreshold"><type><UINT/></type></variable>
            <variable name="RawForcedOutput"><type><UINT/></type></variable>
            <variable name="RawSequence"><type><UDINT/></type></variable>
            <variable name="RawOutputCommand"><type><UINT/></type></variable>
          </externalVars>
          <localVars>
            <variable name="sensor_value"><type><UINT/></type></variable>
            <variable name="threshold"><type><UINT/></type></variable>
            <variable name="remote_output_echo"><type><UINT/></type></variable>
            <variable name="sequence"><type><UDINT/></type></variable>
            <variable name="alarm"><type><BOOL/></type></variable>
            <variable name="output_command"><type><UINT/></type></variable>
          </localVars>
        </interface>
        <body>
          <ST>
            <xhtml:p><![CDATA[sensor_value := RawSensorValue;
threshold := RawThreshold;
remote_output_echo := RawForcedOutput;
sequence := RawSequence;

alarm := sensor_value > threshold;

IF alarm THEN
    output_command := UINT#1;
ELSE
    output_command := UINT#0;
END_IF;

RawOutputCommand := output_command;]]></xhtml:p>
          </ST>
        </body>
      </pou>
